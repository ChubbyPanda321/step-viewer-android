# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files to always have LF line endings on checkout
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.pro text eol=lf
*.gradle text eol=lf

# Gradle wrapper JAR is binary
gradle/wrapper/gradle-wrapper.jar binary

# Image files are binary
*.png binary
*.ico binary
*.jpg binary
*.jpeg binary
*.wasm binary
